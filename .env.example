VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google API credentials
# Required for Google Drive Picker (Feature: import files from Drive)
# Get your API key at: https://console.cloud.google.com → APIs & Services → Credentials → Create API Key
# Restrict it to the "Google Picker API" and your domain.
VITE_GOOGLE_API_KEY=your_google_browser_api_key

# Required for Google Drive Picker (identifies your app to the Picker UI)
# Same OAuth Client ID used in Supabase Google provider settings.
# Get it at: https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id
